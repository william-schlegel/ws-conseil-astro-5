---
import {
  type CollectionEntry,
  getEntries,
  getEntry,
} from "astro:content";
import {
  projectBriefTransitionName,
  projectTitleTransitionName,
} from "../lib/projectTransitions";
import { displayDate } from "../lib/utils";
import Technos from "./Technos.astro";
import { Image } from "astro:assets";
import logoPicto from "../assets/site/logo-picto.png";

interface Props {
  project: CollectionEntry<"projetCollection">["data"];
  index: number;
}

const { project, index } = Astro.props;
const client = project.client
  ? await getEntry("clientCollection", project.client.id)
  : null;
const technos = project.technos ? await getEntries(project.technos) : [];
const categories = await getEntries(project.categories);
---

<article class="relative flex flex-col bg-bg-white01 rounded-md p-4">
  <a
    href={`/project/${project.slug}`}
    class="absolute inset-0 z-0 rounded-md transition-[outline] ease-in-out duration-200 hover:outline hover:outline-4 hover:outline-primary focus-visible:outline focus-visible:outline-4 focus-visible:outline-primary"
    aria-label={`Ouvrir le projet ${project.name}`}
  />
  <div
    class="relative z-[1] flex flex-col flex-1 min-w-0 pointer-events-none"
    style={`animation: project-appearance 0.8s
  var(--animation-power) ${index * 0.8}s both;`}
  >
  <div class="grid grid-cols-[80px_auto] items-center gap-8">
    <div
      class="h-[80px] aspect-square rounded-full bg-white grid place-items-center"
    >
      {
        client?.data.image ? (
          <Image
            src={client.data.image}
            alt=""
            width={60}
            class="bg-cover bg-center"
          />
        ) : (
          <Image
            src={logoPicto}
            class="bg-cover bg-center"
            width={60}
            height={60}
            alt="WS Conseil - projet personnel"
          />
        )
      }
    </div>
    <h3
      class="text-4xl text-secondary p-0 text-start"
      transition:name={projectTitleTransitionName(project.slug)}
      transition:animate="initial"
    >
      {project.name}
    </h3>
  </div>
  <p class="text-sm text-lightgrey">
    {displayDate(project.startDate, project.endDate)}
  </p>
  {
    project.heroImage && (
      <Image
        class="aspect-[4/3] object-cover"
        src={project.heroImage}
        alt="Image principale du projet"
      />
    )
  }
  <p
    transition:name={projectBriefTransitionName(project.slug)}
    transition:animate="initial"
  >
    {project.brief}
  </p>
  <Technos
    technos={technos}
    containerClass="justify-end"
    itemClass="m-0 p-1 bg-white h-8"
  />
  {
    Array.isArray(categories) && (
      <ul class="flex flex-wrap gap-4">
        {categories.map((cat) => (
          <li class="bg-secondary text-primary px-4 py-2 rounded-full">
            {cat.data.title}
          </li>
        ))}
      </ul>
    )
  }
  </div>
</article>
