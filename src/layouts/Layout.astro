---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { ClientRouter, slide } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
} = Astro.props;

/** Menu / liens internes : ancienne page vers la gauche, nouvelle depuis la droite (navigation retour inversée). */
const pageSlide = slide({ duration: "320ms" });
---

<!doctype html>
<html lang="en" transition:animate="none">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <div transition:name="page-content" transition:animate={pageSlide}>
      <slot />
    </div>
    <Footer />
  </body>
</html>

<style lang="scss">
  $sizes: 800,1024;
  $opacity: 0.8;

  body {
    background-image: linear-gradient(
        0deg,
        rgba(0, 0, 0, $opacity),
        rgba(0, 0, 0, $opacity)
      ),
      url("../assets/site/trail-bretagne-800.webp");
    background-size: auto, cover;
    background-origin: content-box;
    background-position: center center;
    overflow-x: hidden;
    @each $size in $sizes {
      @media screen and (min-width: #{$size}px) {
        background-image: linear-gradient(
            0deg,
            rgba(0, 0, 0, $opacity),
            rgba(0, 0, 0, $opacity)
          ),
          url("../assets/site/trail-bretagne-#{$size}.webp");
      }
    }
  }
</style>
