# SMTP (ex. fournisseur transactionnel ou boîte professionnelle)
SMTP_HOST=
SMTP_PORT=587
# true pour port 465 (SSL direct), sinon STARTTLS sur 587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Réception et en-tête From (doit être autorisé par votre SMTP)
CONTACT_TO=william@wsconseil.com
CONTACT_FROM=
